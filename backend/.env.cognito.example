# 🔐 AWS COGNITO CONFIGURATION
AWS_COGNITO_REGION=us-east-1
AWS_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
AWS_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# 🗄️ GOOGLE CLOUD SQL CONFIGURATION
CLOUD_SQL_HOST=your-cloud-sql-ip-or-proxy
CLOUD_SQL_PORT=5432
CLOUD_SQL_DATABASE=224solutions
CLOUD_SQL_USER=postgres
CLOUD_SQL_PASSWORD=your-secure-password
CLOUD_SQL_CA_CERT=path-to-ca-cert.pem

# Ou via connection string
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Pool settings
DB_POOL_MAX=20
DB_POOL_MIN=5

# Redis (optionnel - cache sessions)
REDIS_URL=redis://your-redis-host:6379
