PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://uakkxaibujzxdiqzpnpr.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVha2t4YWlidWp6eGRpcXpwbnByIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NTkwMDA2NTcsImV4cCI6MjA3NDU3NjY1N30.kqYNdg-73BTP0Yht7kid-EZu2APg9qw-b_KW9z5hJbM
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InVha2t4YWlidWp6eGRpcXpwbnByIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc1OTAwMDY1NywiZXhwIjoyMDc0NTc2NjU3fQ.TTZUBu_5eqBIFZEXTJu47hXbeblDDsrKsIRc4o2cCV4

# JWT Secret (même que Supabase) — ⚠️ ≥ 32 caractères (sinon fail-fast en production :
# un secret faible rend le repli d'auth HS256 forgeable). Laisser vide = repli désactivé.
JWT_SECRET=your-jwt-secret-here

# Internal API Key (Communication entre backends) — ≥ 16 caractères
INTERNAL_API_KEY=your-internal-api-key-here

# Autres secrets d'intégration (centralisés dans config/env.ts, jamais en dur)
DJOMY_CLIENT_SECRET=
PAYPAL_CLIENT_SECRET=
TRANSACTION_SECRET_KEY=
CCP_ENCRYPTION_KEY=
RESEND_API_KEY=

# Email de campagne/transaction (Resend) — REQUIS pour les emails de campagne
# RESEND_API_KEY ci-dessus
# SMS de campagne (Twilio) — REQUIS pour les SMS de campagne
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Expéditeur : un Messaging Service SID (recommandé) OU un VRAI numéro Twilio E.164
# (ex +1xxxxxxxxxx) OU un sender ID alphanumérique approuvé (ex "224Sol").
# ⚠️ Un numéro local non-Twilio (ex 610012681) est REJETÉ par Twilio.
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# Redis (rate-limiting partagé multi-instance + cache + locks)
# Option 1 (recommandée prod) : URL d'un Redis managé (Upstash/Redis Cloud/ElastiCache).
#   rediss:// = TLS (géré automatiquement). Définir REDIS_URL active Redis tout seul.
REDIS_URL=
# Option 2 : host/port/password séparés (Redis auto-hébergé / local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
# Forcer l'activation (défaut: true si REDIS_URL défini OU NODE_ENV=production, sinon false)
REDIS_ENABLED=

# Rate Limiting (limiteur GLOBAL par IP — partagé via Redis)
# 900000 ms = 15 min. ⚠️ 100 req/15min est TRÈS restrictif pour une app web
# (une page = plusieurs appels API) : prévoir une valeur réaliste en prod.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins (séparés par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/backend.log

# Cron Jobs
ENABLE_CRON_JOBS=true

# Email Service (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OpenAI API (pour traitement IA)
OPENAI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Monitoring
ENABLE_MONITORING=true
