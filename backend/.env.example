# 🔐 BACKEND NODE.JS - 224SOLUTIONS
# ⚠️ NE JAMAIS COMMIT CE FICHIER AVEC LES VRAIES VALEURS

# Port du serveur
PORT=3001
NODE_ENV=development

# Supabase Configuration
SUPABASE_URL=https://uakkxaibujzxdiqzpnpr.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (même que Supabase)
JWT_SECRET=your-jwt-secret-here

# Internal API Key (Communication entre backends)
INTERNAL_API_KEY=your-internal-api-key-here

# OAuth Google (Server-side only — NEVER expose CLIENT_SECRET)
OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=your-google-client-secret
OAUTH_REDIRECT_URI=https://your-backend-url/auth/google/callback

# Redis Configuration (optionnel pour cache distribué)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS Origins (séparés par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,https://224solution.net,https://www.224solution.net,https://*.224solution.net

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# Logs
LOG_LEVEL=info
LOG_FILE=./logs/backend.log

# Cron Jobs
ENABLE_CRON_JOBS=true

# Email Service (optionnel)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OpenAI API (pour traitement IA)
OPENAI_API_KEY=

# Monitoring
ENABLE_MONITORING=true
MONITORING_INTERVAL_MS=60000
