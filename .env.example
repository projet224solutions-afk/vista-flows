# ==========================================
# CONFIGURATION VISTA-FLOWS (EXEMPLE)
# ==========================================
# IMPORTANT: Copier ce fichier en .env et remplir avec vos vraies valeurs
# Ne JAMAIS commiter le fichier .env réel !

# ==========================================
# SUPABASE
# ==========================================
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_anon_key_publique_ici
SUPABASE_SERVICE_ROLE_KEY=votre_service_role_key_PRIVEE_ici
# Alias backend (le serveur local lit .env à la racine)
SUPABASE_URL=https://votre-projet.supabase.co
SUPABASE_ANON_KEY=votre_anon_key_publique_ici

# ==========================================
# FIREBASE
# ==========================================
VITE_FIREBASE_API_KEY=votre_firebase_api_key_ici
VITE_FIREBASE_AUTH_DOMAIN=votre-projet.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=votre-projet-id
VITE_FIREBASE_STORAGE_BUCKET=votre-projet.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=votre_app_id_ici

# ==========================================
# GOOGLE CLOUD
# ==========================================
VITE_GOOGLE_CLOUD_API_KEY=votre_gcp_api_key_ici

# ==========================================
# AGORA (AUDIO/VIDEO)
# ==========================================
VITE_AGORA_APP_ID=votre_agora_app_id_ici

# ==========================================
# STRIPE
# ==========================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_votre_key_publique_ici

# ==========================================
# JOMY (PAIEMENTS LOCAUX)
# ==========================================
JOMY_CLIENT_ID=votre_jomy_client_id
JOMY_CLIENT_SECRET=votre_jomy_secret

# ==========================================
# BACKEND (Node.js)
# ==========================================
VITE_BACKEND_URL=http://localhost:3001
VITE_BACKEND_API_URL=http://localhost:3001
VITE_API_URL=http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001
# Optionnel (Capacitor/mobile natif): URL API publique accessible depuis le téléphone
VITE_BACKEND_MOBILE_URL=
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=votre_jwt_secret_aleatoire_long_et_securise

# CORS
CORS_ORIGINS=http://localhost:5173,https://votre-domaine.com

# ENCRYPTION
ENCRYPTION_KEY=votre_cle_chiffrement_32_caracteres_minimum

# INTERNAL API
INTERNAL_API_KEY=votre_api_key_interne_securisee
MONITORING_INTERVAL_MS=60000

# ==========================================
# SÉCURITÉ
# ==========================================
# Génération de clés sécurisées recommandée:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
