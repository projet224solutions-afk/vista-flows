# 🔄 Configuration pour la migration Supabase → Cognito
# Copiez ce fichier en .env.migration et remplissez les valeurs

# === SUPABASE ===
SUPABASE_URL=https://uakkxaibujzxdiqzpnpr.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === AWS COGNITO ===
AWS_COGNITO_REGION=us-east-1
AWS_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX

# === AWS CREDENTIALS (pour le SDK) ===
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# === OPTIONS DE MIGRATION ===
# Mode test: affiche ce qui serait fait sans modifier Cognito
DRY_RUN=true

# Nombre d'utilisateurs traités simultanément
BATCH_SIZE=10

# Délai entre les batchs (ms) pour éviter le throttling AWS
DELAY_MS=500
